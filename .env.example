PORT=3000
HOST=127.0.0.1

JWT_SECRET=abc
REFRESH_TOKEN_EXPIRES_IN_DAYS=7
ACCESS_TOKEN_EXPIRES_IN_SECONDS=900 # 15min

LOG_LEVEL=info

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres123
